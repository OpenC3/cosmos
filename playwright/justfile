# OpenC3 Playwright E2E Test Commands
# Run `just` or `just --list` to see all available commands
#
# Quick Start (Initial Setup):
#   just install          - Install Playwright and browsers
#   just build-plugin     - Build the test plugin (required before first run)
#
# Running Tests:
#   just test             - Run all tests (parallel + serial)
#   just test-parallel    - Run parallel tests only
#   just test-serial      - Run serial tests only

# Default recipe - show available commands
default:
    @just --list

# Initial setup - install Playwright and its browser dependencies
install:
    #!/usr/bin/env bash
    [[ -d $HOME/.cache/ms-playwright ]] && rm -rf $HOME/.cache/ms-playwright
    [[ -d $HOME/Library/Caches/ms-playwright ]] && rm -rf $HOME/Library/Caches/ms-playwright
    rm -rf node_modules
    pnpm install --frozen-lockfile --ignore-scripts
    pnpm exec playwright install --with-deps
    pnpm playwright --version
    ./reset_storage_state.sh

# Initial setup - build the test plugin required for Playwright tests
build-plugin:
    rm -rf openc3-cosmos-pw-test
    ../openc3.sh cli generate plugin PW_TEST --ruby
    cd openc3-cosmos-pw-test && \
        ../../openc3.sh cli generate target PW_TEST --ruby && \
        ../../openc3.sh cli rake build VERSION=1.0.0 && \
        cp openc3-cosmos-pw-test-1.0.0.gem openc3-cosmos-pw-test-1.0.1.gem && \
        ../../openc3.sh cli validate openc3-cosmos-pw-test-1.0.0.gem

# Reset Playwright storage/authentication state
reset-storage-state:
    ./reset_storage_state.sh

# Check that COSMOS is running at http://localhost:2900
check-running:
    #!/usr/bin/env bash
    if ! curl -sf http://localhost:2900 > /dev/null 2>&1; then
        echo "Error: COSMOS is not running at http://localhost:2900"
        echo "Start it with: ./openc3.sh run"
        exit 1
    fi

# Run all tests (parallel then serial)
test: check-running
    pnpm test:parallel --quiet && pnpm test:serial --quiet

# Run only parallel tests
test-parallel *ARGS: check-running
    pnpm test:parallel {{ ARGS }}

# Run only serial tests
test-serial *ARGS: check-running
    pnpm test:serial {{ ARGS }}

# Run enterprise tests
test-enterprise: check-running
    pnpm test:enterprise

# Run a single test file: `just test-file tests/command-sender.p.spec.ts`
test-file FILE: check-running
    pnpm exec playwright test {{ FILE }} --project=chromium

# Run tests with a visible browser window
test-headed: check-running
    pnpm test:parallel --headed && pnpm test:serial --headed

# Run tests in debug mode (opens Playwright inspector)
test-debug: check-running
    PWDEBUG=1 pnpm test:parallel --headed

# Show the last HTML test report
report:
    pnpm exec playwright show-report

# Clean test results and coverage output
clean:
    rm -rf test-results .nyc_output coverage

# Format test files with Prettier
format:
    pnpm format
